#compdef puny-manager
# Install to a directory in $fpath, e.g.:
#   cp completions/_puny-manager ~/.local/share/zsh/site-functions/_puny-manager

_puny_manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--version[Show version]' \
        '--help[Show help]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && return

    case "$state" in
        subcmd)
            local -a cmds
            cmds=(
                'create:Create a new vault'
                'list:List entries'
                'add:Add a new entry'
                'get:Show an entry'
                'rm:Remove an entry'
                'stats:Audit vault'
                'gen:Generate a secure password'
                'passwd:Change master password'
                'edit:Edit an entry'
                'lang:Set language'
                'vault:Manage vaults'
                'howdy:Manage facial unlock'
            )
            _describe -t commands 'subcommand' cmds
            ;;
        args)
            case "$words[1]" in
                vault)
                    _arguments '1:vault command:->vaultcmd' && return
                    case "$state" in
                        vaultcmd)
                            local -a vcmds
                            vcmds=(
                                'list:List vaults'
                                'switch:Switch active vault'
                                'delete:Delete a vault'
                            )
                            _describe -t commands 'vault command' vcmds
                            ;;
                    esac
                    ;;
                howdy)
                    _arguments \
                        '1:howdy command:(enable disable status test)' \
                        '--master-password[Master password (non-interactive)]:password:'
                    ;;
                get)
                    _arguments \
                        '--timeout[Clipboard clear timeout]:seconds:' \
                        '--help[Show help]'
                    ;;
                create)
                    _arguments \
                        '--level[Encryption level]:level:(fast balanced paranoid)' \
                        '--help[Show help]'
                    ;;
                add)
                    _arguments \
                        '--generate[Auto-generate password]' \
                        '--length[Password length]:length:' \
                        '--help[Show help]'
                    ;;
                edit)
                    _arguments \
                        '--generate[Auto-generate password]' \
                        '--length[Password length]:length:' \
                        '--help[Show help]'
                    ;;
                lang)
                    _values 'language' en de fr es ru pt zh
                    ;;
            esac
            ;;
    esac
}

_puny_manager "$@"
